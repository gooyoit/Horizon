{
  "version": "1.0",
  "ai": {
    "provider": "minimax",
    "model": "MiniMax-M2.5",
    "api_key_env": "MINIMAX_API_KEY",
    "temperature": 0.3,
    "max_tokens": 8192,
    "languages": [
      "zh"
    ]
  },
  "wechat": {
    "enabled": false,
    "webhook_key_env": "WECHAT_WEBHOOK_KEY",
    "webhook_url": "http://localhost:8001/api/v1/webhook/send?key={webhook_key}",
    "receivers": [
      {
        "type": "user",
        "name": "User Name",
        "id": "user_id"
      },
      {
        "type": "group",
        "name": "Group Name",
        "id": "group_id",
        "mentioned_list": ["@all"]
      }
    ]
  },
  "sources": {
    "github": [
      {
        "type": "user_events",
        "username": "karpathy",
        "enabled": true
      },
      {
        "type": "repo_releases",
        "owner": "vllm-project",
        "repo": "vllm",
        "enabled": true
      },
      {
        "type": "repo_releases",
        "owner": "sgl-project",
        "repo": "sglang",
        "enabled": true
      },
      {
        "type": "repo_releases",
        "owner": "triton-lang",
        "repo": "triton",
        "enabled": true
      }
    ],
    "hackernews": {
      "enabled": true,
      "fetch_top_stories": 10,
      "min_score": 200
    },
    "producthunt": {
      "enabled": true,
      "fetch_limit": 10
    },
    "weibo": {
      "enabled": true,
      "fetch_limit": 20
    },
    "rss": [
      {
        "name": "Simon Willison",
        "url": "https://simonwillison.net/atom/everything/",
        "enabled": true,
        "category": "ai-tools"
      },
      {
        "name": "GitHub Trending - Daily",
        "url": "https://mshibanami.github.io/GitHubTrendingRSS/daily/all.xml",
        "enabled": true,
        "category": "github-trending"
      },
      {
        "name": "LWN.net",
        "url": "https://lwn.net/headlines/full_text?key=${LWN_KEY}",
        "enabled": true,
        "category": "linux-kernel"
      },
      {
        "name": "Long-Term Winning Index Investing",
        "url": "https://wechat2rss.xlab.app/feed/1f35edb36dfda13906f958fc3047e59ce9c234fe.xml",
        "enabled": true,
        "category": "investment"
      },
      {
        "name": "36kr",
        "url": "https://www.36kr.com/feed",
        "enabled": true,
        "category": "tech-news",
        "fetch_limit": 10
      },
      {
        "name": "The Paper",
        "url": "https://www.thepaper.cn/feed",
        "enabled": true,
        "category": "tech-news"
      },
      {
        "name": "zhihu",
        "url": "https://www.zhihu.com/rss",
        "enabled": true,
        "category": "tech-news"
      },
      {
        "name": "ruanyifeng",
        "url": "https://www.ruanyifeng.com/blog/atom.xml",
        "enabled": true,
        "category": "tech-news"
      },
      {
        "name": "V2EX",
        "url": "https://v2ex.com/index.xml",
        "enabled": true,
        "category": "tech-news",
        "fetch_limit": 10
      },
      {
        "name": "huxiu",
        "url": "https://www.huxiu.com/rss/0.xml",
        "enabled": true,
        "category": "tech-news"
      },
      {
        "name": "IT HOME",
        "url": "https://www.ithome.com/rss/",
        "enabled": true,
        "category": "tech-news",
        "fetch_limit": 20
      }
    ],
    "reddit": {
      "enabled": true,
      "subreddits": [
        {
          "subreddit": "MachineLearning",
          "enabled": true,
          "sort": "hot",
          "time_filter": "day",
          "fetch_limit": 15,
          "min_score": 60
        },
        {
          "subreddit": "LocalLLaMA",
          "enabled": true,
          "sort": "hot",
          "time_filter": "day",
          "fetch_limit": 15,
          "min_score": 60
        },
        {
          "subreddit": "SideProject",
          "enabled": true,
          "sort": "hot",
          "time_filter": "day",
          "fetch_limit": 15,
          "min_score": 60
        },
        {
